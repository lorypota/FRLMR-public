{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Git: Sync Both Remotes",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "git push origin HEAD; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; git push FRLSR HEAD; exit $LASTEXITCODE"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
